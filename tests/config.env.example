# tests/config.env  —  copy this file to `tests/config.env` (gitignored) and fill in YOUR values.
#
# The harness carries NO hardcoded workspace specifics; it reads them from here. Bash scripts source
# this file automatically; the Python e2e harness auto-loads it too (already-set env vars win, so
# `WORKSHOP_CATALOG=... python3 tests/e2e/run.py` still overrides a line below).
#
# Plain KEY=value (no `export`, no quotes). Lines starting with # are ignored.

# --- core (Layer 0/1 + Layer 2) ---
WORKSHOP_PROFILE=            # deployer CLI profile (your privileged deployer identity)
WORKSHOP_CATALOG=           # the shared catalog the admin pre-created
WORKSHOP_PRIVILEGED_GROUP=   # the account group whose members see unmasked data
WORKSHOP_WAREHOUSE=          # a SQL warehouse id you can use
WORKSHOP_PREFIX=             # schema prefix for teardown; leave blank to let run.py derive it from the deployer email

# --- Layer 2 differential tests (optional) ---
WORKSHOP_GROUPB_PROFILE=     # a non-privileged human profile (direct-SQL redaction check)
WORKSHOP_SP_PRIV_PROFILE=sp-priv   # ~/.databrickscfg profile for the privileged test SP (MCP/review OBO)
WORKSHOP_SP_REG_PROFILE=sp-reg     # ~/.databrickscfg profile for the non-privileged test SP

# --- one-time SP setup (tests/e2e/setup_sps.py + grant_sps.py) ---
WORKSHOP_ADMIN_PROFILE=      # account/workspace admin profile (create SPs; GRANT USE CATALOG)
WORKSHOP_NONPRIV_GROUP=      # an account group the reg SP joins that is NOT the privileged group
WORKSHOP_ACCOUNT_ID=         # Databricks account id
WORKSHOP_HOST=               # workspace host URL, e.g. https://<workspace>.cloud.databricks.com
WORKSHOP_WORKSPACE_ID=       # workspace id (numeric)
WORKSHOP_SP_PRIV_NAME=workshop-obo-sp-priv   # display name for the privileged test SP
WORKSHOP_SP_REG_NAME=workshop-obo-sp-reg     # display name for the non-privileged test SP
